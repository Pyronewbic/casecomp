# Required for eBay Browse API (client credentials)
# Create keys at https://developer.ebay.com/
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# Optional: Marketplace Insights API (restricted; token scope is requested automatically).
# If you lack access, the script falls back to sold-listing HTML scrape.

# LLM grading — use one or the other when --grade-mode llm
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Site grading — provider-specific (most are placeholders for self-hosted / partner APIs)
TCGRADER_API_URL=
TCGRADER_API_KEY=
POKEGRADE_API_URL=
POKEGRADE_API_KEY=
SNAPGRADE_API_URL=
SNAPGRADE_API_KEY=

# Self-hosted grader (e.g. github.com/crimsonthinker/psa_pokemon_cards)
LOCAL_GRADER_URL=
